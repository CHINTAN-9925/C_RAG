# Required: Groq (free tier) for chat. Get a key at https://console.groq.com
GROQ_API_KEY=gsk_...

# Optional: enables the web-search correction step (INCORRECT / AMBIGUOUS verdicts).
# Without it the app still works, but self-correction falls back to documents only.
TAVILY_API_KEY=tvly-...

# Embeddings run locally via HuggingFace, so no embedding API key is needed.

# Only if you switch back to the paid OpenAI stack in crag_engine.py:
# OPENAI_API_KEY=sk-...
